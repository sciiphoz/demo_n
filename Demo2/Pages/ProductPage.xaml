<Page x:Class="Demo2.Pages.ProductPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Demo2.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProductPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"></RowDefinition>
            <RowDefinition Height="5*"></RowDefinition>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBox x:Name="SearchTB" Height="25" Width="125" Margin="10" TextChanged="SearchTB_TextChanged"></TextBox>
            <ComboBox x:Name="FilterCB" Height="25" Width="75" Margin="10" SelectionChanged="FilterCB_SelectionChanged"></ComboBox>
            <ComboBox x:Name="SortCB" Height="25" Width="75" Margin="10" SelectionChanged="SortCB_SelectionChanged">
                <ComboBoxItem>По умолчанию</ComboBoxItem>
                <ComboBoxItem>По цене (убыв.)</ComboBoxItem>
                <ComboBoxItem>По цене (возр.)</ComboBoxItem>
            </ComboBox>
            
            <Button x:Name="ResetButton" Padding="10 5" Margin="10" Click="ResetButton_Click">По умолчанию</Button>
            <Button x:Name="AddButton" Padding="10 5" Margin="10" Click="AddButton_Click">Добавить</Button>
            <Button x:Name="DeleteButton" Padding="10 5" Margin="10" Click="DeleteButton_Click">Удалить</Button>
        </StackPanel>
        
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ListView x:Name="MainListView" ItemsSource="{Binding}" MouseDoubleClick="MainListView_MouseDoubleClick">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition></ColumnDefinition>
                                    <ColumnDefinition></ColumnDefinition>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel  Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Image Height="150" Margin="10 0">
                                        <Image.Source>
                                            <Binding Path="Image">
                                                <Binding.TargetNullValue>
                                                    <ImageSource>/Media/Products/picture.png</ImageSource>
                                                </Binding.TargetNullValue>
                                            </Binding>
                                        </Image.Source>
                                    </Image>

                                    <StackPanel Grid.Column="0" Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}"></TextBlock>
                                        <TextBlock Text="{Binding Category.Name}"></TextBlock>
                                        <TextBlock Text="{Binding Measurement.Name}"></TextBlock>
                                        <TextBlock Text="{Binding Manufacturer.Name}"></TextBlock>
                                        <TextBlock Text="{Binding Supplier.Name}"></TextBlock>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ScrollViewer>
    </Grid>
</Page>
