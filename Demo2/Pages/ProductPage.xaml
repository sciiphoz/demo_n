<Page x:Class="Demo2.Pages.ProductPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Demo2.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProductPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"></RowDefinition>
            <RowDefinition Height="5*"></RowDefinition>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBox x:Name="SearchTB" Height="25" Width="125" Margin="10" TextChanged="SearchTB_TextChanged"></TextBox>
            <ComboBox x:Name="FilterCB" Height="25" Width="75" Margin="10" SelectionChanged="FilterCB_SelectionChanged"></ComboBox>
            <ComboBox x:Name="SortCB" Height="25" Width="75" Margin="10" SelectionChanged="SortCB_SelectionChanged">
                <ComboBoxItem>По умолчанию</ComboBoxItem>
                <ComboBoxItem>По цене (убыв.)</ComboBoxItem>
                <ComboBoxItem>По цене (возр.)</ComboBoxItem>
            </ComboBox>
            
            <Button x:Name="ResetButton" Padding="10 5" Margin="10" Click="ResetButton_Click">По умолчанию</Button>
            <Button x:Name="AddButton" Padding="10 5" Margin="10" Click="AddButton_Click">Добавить</Button>
            <Button x:Name="DeleteButton" Padding="10 5" Margin="10" Click="DeleteButton_Click">Удалить</Button>
        </StackPanel>
        
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ListView x:Name="MainListView" ItemsSource="{Binding}" MouseDoubleClick="MainListView_MouseDoubleClick">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="ItemBorder">
                            <Grid>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Image Height="150" Margin="10">
                                        <Image.Source>
                                            <Binding Path="Image">
                                                <Binding.TargetNullValue>
                                                    <ImageSource>/Media/Products/picture.png</ImageSource>
                                                </Binding.TargetNullValue>
                                            </Binding>
                                        </Image.Source>
                                    </Image>

                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0 10">
                                            <TextBlock Text="{Binding Category.Name}" FontWeight="Bold"></TextBlock>
                                            <TextBlock FontWeight="Bold">|</TextBlock>
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold"></TextBlock>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Desc, StringFormat={}Описание товара: {0}}"></TextBlock>
                                        <TextBlock Text="{Binding Manufacturer.Name, StringFormat={}Производитель: {0}}"></TextBlock>
                                        <TextBlock Text="{Binding Supplier.Name, StringFormat={}Поставщик: {0}}"></TextBlock>

                                        <!-- Цена со скидкой или обычная -->
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Price, StringFormat={}Стоимость: {0:C}}" Margin="0,0,10,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="TextDecorations" Value="None"/>
                                                        <Setter Property="Foreground" Value="Black"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasDiscount}" Value="True">
                                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                                <Setter Property="Foreground" Value="Red"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <TextBlock Text="{Binding FinalPrice, StringFormat={}Итоговая цена: {0:C}}" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasDiscount}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>

                                        <TextBlock Text="{Binding Measurement.Name, StringFormat={}Единица измерения: {0}}"></TextBlock>
                                        <TextBlock Text="{Binding Quantity, StringFormat={}Количество на складе: {0}}"></TextBlock>
                                    </StackPanel>

                                    <!-- Скидка -->
                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DiscountDisplay}" FontWeight="Bold" FontSize="16"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <DataTemplate.Triggers>
                            <!-- Скидка > 12% -->
                            <DataTrigger Binding="{Binding IsHighDiscount}" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#F4A460"/>
                            </DataTrigger>

                            <!-- Нет на складе -->
                            <DataTrigger Binding="{Binding IsOutOfStock}" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="LightBlue"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ScrollViewer>
    </Grid>
</Page>
